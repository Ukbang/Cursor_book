rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자 프로필 - 본인만 읽기/쓰기
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 스터디 - 로그인한 누구나 읽기, 모임장만 생성/수정
    match /studies/{studyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.leaderId == request.auth.uid ||
        // 신청 승인 시 currentMembers 업데이트 허용
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentMembers'])
      );
      allow delete: if request.auth != null && resource.data.leaderId == request.auth.uid;
    }

    // 신청서 - 로그인한 누구나 읽기/쓰기 (본인 신청 + 모임장 관리)
    match /applications/{appId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
